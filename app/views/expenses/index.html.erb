<% content_for :title, "Despesas" %>
<div class="page-header">
  <div>
    <h1 class="page-title">Despesas</h1>
    <span class="page-subtitle">Todas as suas despesas registradas</span>
  </div>
  <%= link_to "Nova despesa", new_expense_path, class: "btn-primary" %>
</div>
<div class="card">
  <% if @expenses.empty? %>
    <div class="empty-state">
      <svg width="40" height="40" viewBox="0 0 16 16" fill="none" stroke="#6B7EBD" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="4" width="12" height="9" rx="1.5"/>
        <path d="M2 7h12"/>
        <path d="M6 10.5h4"/>
      </svg>
      <p>Nenhuma despesa registrada ainda.</p>
      <%= link_to "Registrar primeira despesa", new_expense_path, class: "link" %>
    </div>
  <% else %>
    <div class="expense-list">
      <% @expenses.each do |expense| %>
        <div class="expense-list__item">
          <%= render expense %>
          <div class="expense-list__actions">
            <%= link_to "Ver", expense, class: "btn-ghost btn-ghost--sm" %>
            <%= link_to "Editar", edit_expense_path(expense), class: "btn-ghost btn-ghost--sm" %>
            <%= button_to "Excluir", expense, method: :delete, class: "btn-danger btn-danger--sm", form: { data: { turbo_confirm: "Tem certeza?" } } %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>