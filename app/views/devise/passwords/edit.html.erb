<div class="devise-container">
  <div class="devise-card">
    <div class="devise-brand">
      <div class="devise-brand-icon">
        <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="12" height="10" rx="2"/>
          <path d="M2 7h12"/>
          <path d="M6 11h4"/>
        </svg>
      </div>
      <span class="devise-brand-name">FinCtrl</span>
    </div>
    <h2>Nova senha</h2>
    <p class="devise-subtitle">Escolha uma senha segura para sua conta</p>
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>
      <div class="field">
        <%= f.label :password, "Nova senha" %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", placeholder: "••••••••" %>
        <% if @minimum_password_length %>
          <span class="password-hint">Mínimo de <%= @minimum_password_length %> caracteres</span>
        <% end %>
      </div>
      <div class="field">
        <%= f.label :password_confirmation, "Confirmar nova senha" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••" %>
      </div>
      <div class="actions">
        <%= f.submit "Redefinir senha" %>
      </div>
    <% end %>
    <div class="devise-divider"><span>ou</span></div>
    <div class="devise-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>