<% content_for :title, "Despesa" %>
<div class="page-header">
  <h1 class="page-title">Despesa</h1>
  <%= link_to expenses_path, class: "btn-back" do %>
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 12L6 8l4-4"/>
    </svg>
    Voltar
  <% end %>
</div>
<div class="detail-card">
  <div class="detail-amount">
    R$ <%= number_with_precision(@expense.amount, precision: 2, delimiter: ".", separator: ",") %>
  </div>
  <div class="detail-fields">
    <div class="detail-row">
      <span class="detail-label">Descrição</span>
      <span class="detail-value"><%= @expense.description %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Categoria</span>
      <span class="detail-value"><%= @expense.category.name %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Data</span>
      <span class="detail-value"><%= @expense.date.strftime("%d/%m/%Y") %></span>
    </div>
  </div>
  <div class="detail-actions">
    <%= link_to "Editar", edit_expense_path(@expense), class: "btn-ghost" %>
    <%= button_to "Excluir", @expense, method: :delete, class: "btn-danger", form: { data: { turbo_confirm: "Tem certeza?" } } %>
  </div>
</div>