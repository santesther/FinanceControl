<% content_for :title, "Alerta" %>
<div class="page-header">
  <h1 class="page-title">Detalhe do Alerta</h1>
  <%= link_to alerts_path, class: "btn-back" do %>
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 12L6 8l4-4"/>
    </svg>
    Voltar
  <% end %>
</div>
<div class="detail-card">
  <%= render @alert %>
  <div class="detail-fields">
    <div class="detail-row">
      <span class="detail-label">Despesa relacionada</span>
      <span class="detail-value">
        <%= link_to "Ver despesa", expense_path(@alert.expense), class: "link" %>
      </span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Enviado em</span>
      <span class="detail-value"><%= @alert.sent_at&.strftime("%d/%m/%Y %H:%M") || "—" %></span>
    </div>
  </div>
</div>