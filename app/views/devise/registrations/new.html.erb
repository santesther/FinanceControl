<div class="devise-container">
  <div class="devise-card">
    <div class="devise-brand">
      <div class="devise-brand-icon">
        <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="12" height="10" rx="2"/>
          <path d="M2 7h12"/>
          <path d="M6 11h4"/>
        </svg>
      </div>
      <span class="devise-brand-name">FinCtrl</span>
    </div>
    <h2>Criar conta</h2>
    <p class="devise-subtitle">Comece a controlar suas finanças hoje</p>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <div class="field">
        <%= f.label :email %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "seu@email.com" %>
      </div>
      <div class="field">
        <%= f.label :password %>
        <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••" %>
        <% if @minimum_password_length %>
          <span class="password-hint">Mínimo de <%= @minimum_password_length %> caracteres</span>
        <% end %>
      </div>
      <div class="field">
        <%= f.label :password_confirmation %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••" %>
      </div>
      <div class="actions">
        <%= f.submit "Criar conta" %>
      </div>
    <% end %>
    <div class="devise-divider"><span>ou</span></div>
    <div class="devise-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>