<% content_for :title, "Meta Mensal" %>
<div class="page-header">
  <h1 class="page-title">Meta Mensal</h1>
  <%= link_to monthly_goals_path, class: "btn-back" do %>
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 12L6 8l4-4"/>
    </svg>
    Voltar
  <% end %>
</div>
<div class="detail-card">
  <%= render @monthly_goal %>
  <div class="detail-actions">
    <%= link_to "Editar", edit_monthly_goal_path(@monthly_goal), class: "btn-ghost" %>
    <%= button_to "Excluir", @monthly_goal, method: :delete, class: "btn-danger", form: { data: { turbo_confirm: "Tem certeza?" } } %>
  </div>
</div>